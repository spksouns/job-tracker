# Step 1: Use Java 21 to BUILD the jar
FROM eclipse-temurin:21-jdk-alpine AS builder

# Step 2: Set working folder inside container
WORKDIR /app

# Step 3: Copy all project files into container
COPY . .

# Step 4: Build the jar file (skip tests — already tested!)
RUN ./gradlew bootJar -x test

# ─────────────────────────────────────────
# Step 5: Fresh container just to RUN the jar
# (smaller size — no build tools needed)
FROM eclipse-temurin:21-jre-alpine

# Step 6: Set working folder
WORKDIR /app

# Step 7: Copy ONLY the jar from builder above
COPY --from=builder /app/build/libs/job-tracker-0.0.1-SNAPSHOT.jar app.jar

# Step 8: Tell Docker this app uses port 8080
EXPOSE 8080

# Step 9: Command to start the app
ENTRYPOINT ["java", "-jar", "app.jar"]
